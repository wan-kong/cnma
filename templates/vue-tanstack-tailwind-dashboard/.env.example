VITE_API_MODE="mock"
VITE_GLOBAL_APP_TITLE="__PROJECT_NAME__"

# 应用部署根路径，同时作为 base 与接口请求前缀（URL_ROOT）。
VITE_ROOT_PREFIX_URL=""

# 代理信息（仅 dev server 生效），格式：[prefix, target, rewrite?]
# - prefix 会自动拼上 VITE_ROOT_PREFIX_URL；
# - 同名 VITE_PROXY_* 后面的配置覆盖前面的；
# - rewrite 为可选项，转发前从路径中剔除的片段。
# 实际使用时拷贝本文件为 .env.development.local 并按需修改。
VITE_PROXY_BASE=["/api","http://localhost:8000"]
